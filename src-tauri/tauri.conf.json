{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clide",
  "version": "0.1.78",
  "identifier": "com.dlbury.clide",
  "build": {
    "beforeDevCommand": "node scripts/start-next-dev.mjs 13800",
    "devUrl": "http://localhost:13800",
    "frontendDist": "../view/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clide",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "visible": true,
        "center": true,
        "focus": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "deb",
      "rpm",
      "appimage",
      "dmg",
      "app"
    ],
    "resources": {
      "../scripts/run-aiterm-mcp.mjs": "scripts/run-aiterm-mcp.mjs",
      "../scripts/aiterm-mcp-stdio.mjs": "scripts/aiterm-mcp-stdio.mjs"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1 | libappindicator3-1"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "icons/nsis/installer-sidebar.bmp",
        "headerImage": "icons/nsis/installer-header.bmp",
        "uninstallerIcon": "icons/icon.ico",
        "uninstallerHeaderImage": "icons/nsis/uninstaller-header.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1QUI0Q0QyQzM5OUJFNzUKUldSMXZwbkQwa3lyZFV6NEhFTTlNV2laTmsvNi80YWQ2WG9JVG1jMXZnZW1pRm80SGFPRkVYOE8K",
      "endpoints": [
        "https://github.com/DLbury/clide/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
