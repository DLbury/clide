{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clide",
  "version": "0.1.39",
  "identifier": "com.dlbury.clide",
  "build": {
    "beforeDevCommand": "node scripts/start-next-dev.mjs 13800",
    "devUrl": "http://localhost:13800",
    "frontendDist": "../view/out"
  },
  "app": {
    "windows": [
      {
        "title": "Clide",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "visible": true,
        "center": true,
        "focus": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/run-aiterm-mcp.mjs": "scripts/run-aiterm-mcp.mjs",
      "../scripts/aiterm-mcp-stdio.mjs": "scripts/aiterm-mcp-stdio.mjs"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1 | libappindicator3-1"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
