{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clide",
  "version": "0.1.20",
  "identifier": "com.dlbury.clide",
  "build": {
    "beforeDevCommand": "npm run dev --prefix view",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../view/out"
  },
  "app": {
    "windows": [
      {
        "title": "Clide",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "visible": true,
        "center": true,
        "focus": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../scripts/run-aiterm-mcp.mjs",
      "../scripts/aiterm-mcp-stdio.mjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
